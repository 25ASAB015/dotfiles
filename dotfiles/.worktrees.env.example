# Example configuration for scripts/worktrees.sh

# Root directory for all worktrees
WORKTREES_ROOT="${REPO_ROOT}/worktrees"

# Branches to exclude from implicit operations
EXCLUDE_BRANCHES="main"

# Default base branch when creating new branches
DEFAULT_BASE_BRANCH="main"

# Automatically push new branches created via `new` or when missing in `create`
AUTO_PUSH_NEW_BRANCHES="false"

# Run pre-commit when available during task phases
RUN_PRE_COMMIT="false"

# dotbare / fzf integration
ENABLE_DOTBARE="true"
DOTBARE_CMD="dotbare"
FZF_CMD="fzf"

# Parallel execution
ENABLE_PARALLEL="false"
# PARALLEL_JOBS="8"

# Validations & conventions
ENFORCE_PRE_PUSH="true"
HALT_ON_VALIDATION_FAIL="true"
RUN_COMMITLINT="false"
COMMITLINT_CMD="npx --yes commitlint"
COMMITLINT_RANGE_MODE="last"  # or "range"
BRANCH_NAME_REGEX="^(feat|fix|chore|docs|refactor|test|build|ci|perf|style)\/[a-z0-9._-]+$"
ENFORCE_BRANCH_CONVENTION="true"

# Optional lifecycle tasks (executed in each worktree)
# Use shell commands; separate multiple with `&&` or write a script and call it
# PRE_CREATE_TASKS="npm ci"
# POST_CREATE_TASKS="pre-commit install"
# PRE_UPDATE_TASKS=""
# POST_UPDATE_TASKS=""
# PRE_PUSH_TASKS=""
# POST_PUSH_TASKS=""
# PRE_DIFF_TASKS=""
# POST_DIFF_TASKS=""
